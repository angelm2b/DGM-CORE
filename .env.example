APP_NAME="DGM CORE"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dgm_core
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@dgm.gob.do"
MAIL_FROM_NAME="${APP_NAME}"

# Clave admin para acceder a la documentación de la API en producción.
DGM_DOCS_PASSWORD=cambia-esta-clave
# Días calendario de inactividad para caducar una solicitud (RN-07).
DGM_CADUCIDAD_DIAS=90
# Días de validez de una orden de pago.
DGM_ORDEN_PAGO_VIGENCIA_DIAS=15

# Versión mostrada en la documentación OpenAPI (Scramble).
API_VERSION=0.0.1
# Prefijo de los tokens personales de Sanctum (vacío = sin prefijo).
# Útil para escaneo de secretos en repos. La API es solo Bearer, por lo que
# SANCTUM_STATEFUL_DOMAINS (auth por cookie de SPA) no aplica y se omite.
SANCTUM_TOKEN_PREFIX=

# Contraseña por defecto para los usuarios de demo creados por el seeder
# (solo entornos locales). Si se deja vacía, el seeder genera una aleatoria.
SEED_DEFAULT_PASSWORD=secret123

VITE_APP_NAME="${APP_NAME}"
